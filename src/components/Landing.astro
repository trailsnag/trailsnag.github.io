---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import QrSticker from './QrSticker.astro';
import { useTranslations, claimUrl, contactEmail } from '../i18n/utils';
import type { Lang } from '../i18n/routes';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t.meta.title} description={t.meta.description}>
  <Header lang={lang} anchors />

  <main>
    <!-- Hero: the promise on the left, the physical artifact on the right. -->
    <section class="mx-auto max-w-6xl px-5 pt-14 pb-16 sm:pt-20">
      <div class="grid items-center gap-12 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="font-mono text-sm font-semibold tracking-wide text-(--pine) uppercase">
            {t.hero.kicker}
          </p>
          <h1 class="mt-4 font-display tracking-[-0.03em]">
            <span class="block text-2xl leading-snug font-bold text-(--sub) sm:text-3xl">
              {t.hero.h1a}
            </span>
            <span class="mt-3 block text-5xl leading-[1.02] font-extrabold text-(--ink) sm:text-6xl lg:text-7xl">
              {t.hero.h1b}<span class="text-(--blaze)">.</span>
            </span>
          </h1>
          <p class="mt-6 max-w-xl text-lg leading-relaxed text-(--sub)">{t.hero.lead}</p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a
              href={claimUrl}
              class="rounded-(--radius-control) bg-(--blaze) px-6 py-3.5 text-base font-bold text-white transition-colors duration-200 hover:bg-(--blaze-hover) active:bg-(--blaze-press)"
              >{t.hero.ctaPrimary}</a
            >
            <a
              href="#how"
              class="rounded-(--radius-control) border border-(--line) px-6 py-3.5 text-base font-bold text-(--ink) transition-colors duration-200 hover:border-(--pine)"
              >{t.hero.ctaSecondary}</a
            >
          </div>
          <p class="mt-4 font-mono text-sm text-(--sub)">{t.hero.ctaNote}</p>
        </div>
        <div>
          <QrSticker />
          <p class="mt-5 text-center text-sm text-(--sub)">{t.sticker.caption}</p>
        </div>
      </div>
    </section>

    <!-- Visitor side: a real sequence, so the numbers mean something. -->
    <section id="how" class="scroll-mt-20 border-t border-(--line)">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
        <p class="font-mono text-sm font-semibold tracking-wide text-(--pine) uppercase">
          {t.how.kicker}
        </p>
        <h2 class="mt-3 font-display text-3xl font-extrabold tracking-[-0.02em] text-(--ink) sm:text-4xl">
          {t.how.title}<span class="text-(--blaze)">.</span>
        </h2>
        <ol class="mt-10 grid gap-6 md:grid-cols-3">
          {
            t.how.steps.map((step, i) => (
              <li class="rounded-(--radius-card) border border-(--line) bg-(--card) p-6">
                <div class="flex items-center gap-3">
                  <span class="blaze-stripe" aria-hidden="true" />
                  <span class="font-mono text-sm font-semibold text-(--sub)">{i + 1}/3</span>
                </div>
                <h3 class="mt-4 font-display text-xl font-bold tracking-[-0.02em] text-(--ink)">
                  {step.title}
                </h3>
                <p class="mt-2 leading-relaxed text-(--sub)">{step.body}</p>
              </li>
            ))
          }
        </ol>
        <p class="mt-6 max-w-2xl text-sm leading-relaxed text-(--sub)">{t.how.note}</p>
      </div>
    </section>

    <!-- The incentive loop: points earned on the trail, redeemed with the land.
         The badge sits on the redemption card only — points accrue today, the
         catalog ships with F9, and the site never claims otherwise. -->
    <section id="rewards" class="scroll-mt-20 border-t border-(--line)">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
        <p class="font-mono text-sm font-semibold tracking-wide text-(--pine) uppercase">
          {t.rewards.kicker}
        </p>
        <h2 class="mt-3 font-display text-3xl font-extrabold tracking-[-0.02em] text-(--ink) sm:text-4xl">
          {t.rewards.title}<span class="text-(--blaze)">.</span>
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-(--sub)">{t.rewards.lead}</p>
        <div class="mt-10 grid gap-6 md:grid-cols-3">
          {
            t.rewards.cards.map((card, i) => (
              <article class="rounded-(--radius-card) border border-(--line) bg-(--card) p-6">
                <div class="flex items-center justify-between gap-3">
                  <span class="blaze-stripe" aria-hidden="true" />
                  {i === 1 && (
                    <span class="rounded-full border border-(--line) bg-(--quiet) px-3 py-1 font-mono text-xs font-semibold text-(--sub)">
                      {t.rewards.badge}
                    </span>
                  )}
                </div>
                <h3 class="mt-4 font-display text-xl font-bold tracking-[-0.02em] text-(--ink)">
                  {card.title}
                </h3>
                <p class="mt-2 leading-relaxed text-(--sub)">{card.body}</p>
              </article>
            ))
          }
        </div>
        <p class="mt-6 max-w-2xl text-sm leading-relaxed text-(--sub)">{t.rewards.note}</p>
      </div>
    </section>

    <!-- Steward side: the dark painted sign in the middle of the page. -->
    <section id="stewards" class="scroll-mt-20 bg-(--ink-band,#0f1f1a)">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
        <p class="font-mono text-sm font-semibold tracking-wide text-[#7fb59d] uppercase">
          {t.stewards.kicker}
        </p>
        <h2 class="mt-3 max-w-2xl font-display text-3xl font-extrabold tracking-[-0.02em] text-[#f1f4ee] sm:text-4xl">
          {t.stewards.title}<span class="text-[#e2703a]">.</span>
        </h2>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-[#d5e0d3]">{t.stewards.lead}</p>
        <div class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2">
          {
            t.stewards.features.map((f) => (
              <div class="border-t border-[#2e5a4c] pt-5">
                <h3 class="font-display text-lg font-bold tracking-[-0.02em] text-[#f1f4ee]">
                  {f.title}
                </h3>
                <p class="mt-2 leading-relaxed text-[#b7c4b2]">{f.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Who it serves, in the order they pay — clubs stay free, and say so. -->
    <section class="border-t border-(--line)">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:py-20">
        <p class="font-mono text-sm font-semibold tracking-wide text-(--pine) uppercase">
          {t.audiences.kicker}
        </p>
        <h2 class="mt-3 font-display text-3xl font-extrabold tracking-[-0.02em] text-(--ink) sm:text-4xl">
          {t.audiences.title}<span class="text-(--blaze)">.</span>
        </h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-2 xl:grid-cols-4">
          {
            t.audiences.cards.map((card) => (
              <article class="flex flex-col rounded-(--radius-card) border border-(--line) bg-(--card) p-6">
                <span class="self-start rounded-full border border-(--line) bg-(--quiet) px-3 py-1 font-mono text-xs font-semibold text-(--sub)">
                  {card.badge}
                </span>
                <h3 class="mt-4 font-display text-xl font-bold tracking-[-0.02em] text-(--ink)">
                  {card.title}
                </h3>
                <p class="mt-2 leading-relaxed text-(--sub)">{card.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Close: one action, one address. -->
    <section class="mx-auto max-w-6xl px-5 pb-20">
      <div class="rounded-(--radius-sheet) bg-(--quiet) px-6 py-14 text-center sm:px-12">
        <h2 class="mx-auto max-w-2xl font-display text-3xl font-extrabold tracking-[-0.02em] text-(--ink) sm:text-4xl">
          {t.ctaBand.title}
        </h2>
        <p class="mx-auto mt-4 max-w-xl leading-relaxed text-(--sub)">{t.ctaBand.body}</p>
        <div class="mt-8 flex flex-col items-center gap-4">
          <a
            href={claimUrl}
            class="rounded-(--radius-control) bg-(--blaze) px-7 py-4 text-base font-bold text-white transition-colors duration-200 hover:bg-(--blaze-hover) active:bg-(--blaze-press)"
            >{t.ctaBand.cta}</a
          >
          <p class="text-sm text-(--sub)">
            {t.ctaBand.mailLead}
            <a href={`mailto:${contactEmail}`} class="font-mono font-semibold text-(--ink) underline decoration-(--line) underline-offset-4 hover:decoration-(--blaze)">{contactEmail}</a>
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* The steward band is a painted sign: pine-950 in light mode, the dark
     card surface when the whole page is already dark. */
  #stewards {
    --ink-band: #0f1f1a;
  }
  @media (prefers-color-scheme: dark) {
    #stewards {
      --ink-band: #161d16;
    }
  }
</style>
