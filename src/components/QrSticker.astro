---
// The trailhead sticker, depicted life-size-ish: the product's one physical
// artifact. The QR is real and generated at build time — it opens the actual
// app. The sticker text stays French-predominant bilingual in both locales
// because that is what the printed Québec sticker looks like (Bill 96), and a
// printed object does not switch languages with the page. It also stays paper
// in dark mode for the same reason.
import QRCode from 'qrcode';
import BlazedPin from './BlazedPin.astro';
import { appUrl } from '../i18n/utils';

const qrSvg = await QRCode.toString(appUrl, {
  type: 'svg',
  margin: 0,
  errorCorrectionLevel: 'M',
  color: { dark: '#0f1f1a', light: '#0000' },
});
---

<figure class="sticker-enter sticker-tilt mx-auto w-full max-w-xs">
  <div
    class="rounded-(--radius-sheet) border border-[#d5e0d3] bg-white p-6 shadow-[0_18px_40px_-18px_rgba(15,31,26,0.35)]"
  >
    <div class="flex items-center gap-2 text-[#0f1f1a]">
      <BlazedPin class="h-7 w-auto" />
      <span class="font-display text-lg font-extrabold tracking-[-0.03em]"
        >TrailSnag<span class="text-[#cb561f]">.</span></span
      >
    </div>
    <p class="mt-4 font-display text-xl leading-tight font-bold tracking-[-0.02em] text-[#0f1f1a]">
      Un problème sur le sentier&nbsp;?
    </p>
    <p class="mt-1 text-sm text-[#24483d]">Spot a problem on the trail?</p>
    <div
      class="mt-4 rounded-(--radius-card) border border-[#d5e0d3] bg-[#f1f4ee] p-4 [&_svg]:h-auto [&_svg]:w-full"
      set:html={qrSvg}
    />
    <div class="mt-4 flex items-center justify-between">
      <p class="text-sm font-semibold text-[#0f1f1a]">
        Scannez — 30&nbsp;secondes, sans compte<span class="text-[#cb561f]">.</span>
      </p>
      <span class="blaze-stripe shrink-0" aria-hidden="true"></span>
    </div>
    <p class="mt-3 font-mono text-xs text-[#24483d]">trailsnag.app</p>
  </div>
</figure>
