---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/routes';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Human-readable "last updated" line, already localized. */
  updated?: string;
}
const { lang, title, description, updated } = Astro.props;
---

<BaseLayout lang={lang} title={`${title} — TrailSnag`} description={description}>
  <Header lang={lang} />
  <main class="mx-auto max-w-3xl px-5 py-14">
    <h1 class="font-display text-4xl font-extrabold tracking-[-0.03em] text-(--ink)">
      {title}<span class="text-(--blaze)">.</span>
    </h1>
    {updated && <p class="mt-3 font-mono text-sm text-(--sub)">{updated}</p>}
    <div class="legal mt-8">
      <slot />
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .legal :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 1.35rem;
    color: var(--ink);
    margin-top: 2.25rem;
  }
  .legal :global(p),
  .legal :global(li) {
    color: var(--sub);
    line-height: 1.7;
    margin-top: 0.75rem;
    max-width: 65ch;
  }
  .legal :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
  }
  .legal :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--line);
  }
  .legal :global(a:hover) {
    text-decoration-color: var(--blaze);
  }
</style>
